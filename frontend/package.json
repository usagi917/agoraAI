{
  "name": "frontend",
  "private": true,
  "version": "1.0.0",
  "packageManager": "pnpm@10.34.4",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vue-tsc -b && vite build",
    "build:e2e": "vue-tsc -b && vite build --mode e2e",
    "preview": "vite preview",
    "test:unit": "vitest run",
    "test:e2e": "pnpm build:e2e && playwright test",
    "check:dead": "knip --include files,dependencies,unlisted,unresolved"
  },
  "dependencies": {
    "axios": "^1.13.6",
    "d3-force": "^3.0.0",
    "dompurify": "^3.4.11",
    "force-graph": "^1.51.4",
    "html2canvas": "^1.4.1",
    "jspdf": "^4.2.1",
    "pinia": "^3.0.4",
    "vue": "^3.5.30",
    "vue-router": "^5.0.3"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "@types/d3-force": "^3.0.10",
    "@types/node": "^24.12.0",
    "@vitejs/plugin-vue": "^6.0.5",
    "@vue/test-utils": "^2.4.6",
    "@vue/tsconfig": "^0.9.0",
    "jsdom": "^29.0.1",
    "knip": "^6.7.0",
    "typescript": "~5.9.3",
    "vite": "^8.0.0",
    "vitest": "^4.1.0",
    "vue-tsc": "^3.2.5"
  },
  "knip": {
    "entry": [
      "src/**/*.spec.ts",
      "tests/e2e/**/*.spec.ts"
    ],
    "project": [
      "src/**/*.{ts,vue}",
      "tests/**/*.ts",
      "*.ts"
    ]
  }
}
