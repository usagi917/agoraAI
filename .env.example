# ===========================================
# Agent AI - 環境変数設定
# ===========================================

# LLM Configuration
# OpenAI API キー（必須）
OPENAI_API_KEY=sk-your-key-here

# Google API キー（Society モードの Gemini 利用時に必要）
GOOGLE_API_KEY=your-google-api-key-here

# Anthropic API キー（Society モードの Claude 利用時に必要）
ANTHROPIC_API_KEY=your-anthropic-api-key-here

# デフォルトモデル（config/models.yaml でタスク別に上書き可能）
LLM_MODEL=gpt-5-nano-2025-08-07

# Database
# PostgreSQL: postgresql+asyncpg://agentai:agentai@localhost:5432/agentai
# SQLite（ローカル開発用）: sqlite+aiosqlite:///./data/db.sqlite3
DATABASE_URL=sqlite+aiosqlite:///./data/db.sqlite3

# Redis（キャッシュ・セッション管理、未使用なら省略可）
# REDIS_URL=redis://localhost:6379/0

# Backend
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000

# Frontend
# Docker 環境では http://localhost:8000 に設定
# ローカル開発では Vite proxy が /api を http://localhost:8000 に転送するため不要
VITE_API_BASE_URL=http://localhost:8000

# Swarm Settings
# 同時実行する Colony の最大数
MAX_CONCURRENT_COLONIES=5

# LLM レスポンスキャッシュの有効期間（秒）
LLM_CACHE_TTL=3600

# Cognitive Settings
# legacy: 従来モード / advanced: BDI認知アーキテクチャ + Theory of Mind
COGNITIVE_MODE=advanced

# 認知エージェントの最大数
MAX_ACTIVE_AGENTS=100

# 同時に認知サイクルを実行するエージェント数
MAX_CONCURRENT_AGENTS=30
